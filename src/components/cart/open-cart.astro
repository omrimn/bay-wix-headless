---
import ShoppingCartIcon from "../icons/shopping-cart-icon.astro";
import clsx from "clsx";

type Props = {
  class?: string;
  quantity?: number | undefined;
};
---

<div
  class="relative flex h-11 w-11 items-center justify-center rounded-md border transition-colors border-bay-accent text-white"
>
  <ShoppingCartIcon
    class={clsx(
      "h-4 transition-all ease-in-out hover:scale-110 text-bay-accent",
      Astro.props.class
    )}
  />

  {
    Astro.props.quantity ? (
      <div class="absolute right-0 top-0 -mr-2 -mt-2 h-4 w-4 rounded bg-bay-accent text-[11px] font-medium text-white">
        {Astro.props.quantity}
      </div>
    ) : null
  }
</div>
