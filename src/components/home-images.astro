---
import { getHomeImages } from "../lib/wix/index";
import { getImageUrl } from "../lib/utils.ts";
import { Image } from "astro:assets";

let images: Awaited<ReturnType<typeof getHomeImages>> = [];
try {
  images = await getHomeImages();
  console.log("Home images result:", images?.length || 0, "images found");
} catch (err) {
  console.error("ERROR fetching home images:", err);
  images = [];
}

if (images?.length > 0) {
  images.sort(() => Math.random() - 0.5);
}

if (!images?.length) {
  console.log(
    'HOME-IMAGES: No images loaded - check if "images_accueil" data collection exists',
  );
  return null;
}
---

{
  images && (
    <div class="p-8">
      <h2 class="mb-2 ml-4 text-4xl font-bold text-bay-accent dark:text-white">
        Galerie Photo
      </h2>
      <div class="mx-auto container my-8 sm:columns-2 md:columns-3 lg:columns-4 xl:columns-5">
        {images.map((image) => (
          <img
            src={getImageUrl(image.url)}
            alt={image.altText}
            loading="lazy"
            class:list={[
              "mb-4 rounded-lg transition-all",
              "group-hover:shadow-lg group-hover:opacity-90",
            ]}
          />
        ))}
      </div>
    </div>
  )
}
